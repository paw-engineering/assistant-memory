{
  // ============================================================
  // assistant-memory — per-agent config template
  // ============================================================
  // Copy this file to config/agents/<your-agent-id>/memory-plugin.json
  // and fill in your values. agentId is the only required field.
  // ============================================================

  /**
   * REQUIRED. A unique identifier for this agent instance.
   * Used as the directory name under data/agents/ and as the
   * SQLite DB filename prefix.
   *
   * Example: "virt", "lobs", "dwg-assistant-1"
   */
  "agentId": "your-agent-id",

  /**
   * URL of your LM Studio server (OpenAI-compatible API).
   *
   * VM/macOS UTM:    http://192.168.64.1:1234
   * Docker container: http://host.docker.internal:1234
   *
   * The plugin appends /v1/embeddings automatically.
   */
  "lmStudioUrl": "http://192.168.64.1:1234",

  /**
   * The embedding model loaded in LM Studio.
   * Must output vectors of dimension 2560.
   *
   * Default: "text-embedding-qwen3-embedding-4b"
   */
  "embeddingModel": "text-embedding-qwen3-embedding-4b",

  /**
   * Directory where SQLite DB, FAISS index, and backups are stored.
   * Can be a relative path (resolved from the repo root) or absolute.
   *
   * Default: "data/agents/<agentId>/memory"
   */
  "dataDir": "data/agents/your-agent-id/memory",

  /**
   * --- Optional advanced fields (shown with defaults) ---
   */

  /**
   * Embedding vector dimension. Only change if your model outputs
   * a different number of dimensions.
   *
   * Default: 2560  (qwen3-embedding-4b)
   */
  // "embeddingDimension": 2560,

  /**
   * Batch size for embedding requests. Larger = faster bulk indexing
   * but higher memory usage per request.
   *
   * Default: 32
   */
  // "batchSize": 32,

  /**
   * How often the plugin snapshots the SQLite DB to backup/ (in ms).
   *
   * Default: 300000  (= 5 minutes)
   */
  // "backupIntervalMs": 300000,

  /**
   * Maximum number of rolling backups to keep in backupDir.
   * Oldest backups are deleted first when this limit is reached.
   *
   * Default: 10
   */
  // "maxBackups": 10,

  /**
   * How often the FAISS index is rebuilt from SQLite (in ms).
   * Shorter = faster search freshness but more CPU work.
   *
   * Default: 30000  (= 30 seconds)
   */
  // "indexUpdateIntervalMs": 30000
}
