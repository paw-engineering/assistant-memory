{
  "name": "@paw/assistant-memory",
  "version": "1.0.0",
  "description": "Per-agent memory plugin for DWG Assistants — FAISS indexing, LM Studio embeddings, backup",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --fix",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "faiss-node": "^0.2.1",
    "openai": "^4.90.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.4",
    "jest": "^29.7.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
