{
  "id": "@dwg/assistant-memory",
  "kind": ["memory"],
  "name": "Assistant Memory",
  "description": "Per-agent memory with FAISS vector search, JSON storage, LM Studio embeddings, file indexing, and knowledge graph",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "agentId": {"type": "string", "description": "Unique identifier for this agent (e.g., 'main', 'programmer')"},
      "dataDir": {"type": "string", "description": "Base directory for agent memory data (default: data/agents/{agentId}/memory)"},
      "lmStudioUrl": {"type": "string", "default": "http://192.168.64.1:1234", "description": "LM Studio server URL"},
      "embeddingModel": {"type": "string", "default": "text-embedding-qwen3-embedding-4b", "description": "Embedding model name"},
      "embeddingDimension": {"type": "number", "default": 2560, "description": "Embedding vector dimension"},
      "batchSize": {"type": "number", "default": 32, "description": "Batch size for embedding requests"},
      "backupIntervalMs": {"type": "number", "default": 300000, "description": "Backup interval in milliseconds (5 minutes)"},
      "maxBackups": {"type": "number", "default": 3, "description": "Maximum number of backups to keep"},
      "indexUpdateIntervalMs": {"type": "number", "default": 30000, "description": "Index rebuild interval in milliseconds"},
      "watchDirs": {"type": "array", "items": {"type": "string"}, "default": [], "description": "Directories to watch for file indexing"}
    },
    "required": ["agentId"]
  }
}
