{
  "name": "@dwg/assistant-memory",
  "version": "1.0.0",
  "description": "Per-agent memory plugin with FAISS index, JSON file storage, and LM Studio embeddings",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "types": "./src/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node --import tsx src/index.ts",
    "dev": "node --import tsx --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --fix"
  },
  "dependencies": {
    "faiss-node": "^0.2.1",
    "ajv": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.39.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "versionPinned": "1.0.0",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "agentId": {
        "type": "string",
        "description": "Unique identifier for this agent"
      },
      "dataDir": {
        "type": "string",
        "description": "Base directory for agent data (default: data/agents/{agentId}/memory)"
      },
      "lmStudioUrl": {
        "type": "string",
        "default": "http://192.168.64.1:1234",
        "description": "LM Studio server URL"
      },
      "embeddingModel": {
        "type": "string",
        "default": "text-embedding-qwen3-embedding-4b",
        "description": "Embedding model name"
      },
      "embeddingDimension": {
        "type": "number",
        "default": 2560,
        "description": "Embedding vector dimension"
      },
      "batchSize": {
        "type": "number",
        "default": 32,
        "description": "Batch size for embedding requests"
      },
      "backupIntervalMs": {
        "type": "number",
        "default": 300000,
        "description": "Backup interval in milliseconds (5 minutes)"
      },
      "maxBackups": {
        "type": "number",
        "default": 3,
        "description": "Maximum number of backups to keep"
      },
      "indexUpdateIntervalMs": {
        "type": "number",
        "default": 30000,
        "description": "Index rebuild interval in milliseconds"
      }
    },
    "required": ["agentId"]
  }
}